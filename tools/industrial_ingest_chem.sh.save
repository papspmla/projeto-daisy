#!/usr/bin/env bash
set -euo pipefail
umask 077

# ------------------------------------------------------------
# industrial_ingest_chem.sh
# Orquestra ingestão completa de 1 PDF de chemistry:
#   1) pdftotext -layout -> raw_layout
#   2) ingest_chem.sh (--dry-run + --run)
#   3) registra PDF em Postgres (daisy.documents)
#   4) gera chunks (generate_chem_chunks.sh)
#
# Regra operacional: 1 execução = 1 exame (1 PDF).
# ------------------------------------------------------------

PROJECT_ROOT="/home/paulo/projeto_daisy"
PDF_DIR="${PROJECT_ROOT}/import/pdfs/chemistry"
RAW_DIR="${PROJECT_ROOT}/import/raw"
TOOLS_DIR="${PROJECT_ROOT}/tools"
LOG_DIR="${PROJECT_ROOT}/logs/industrial_ingest"
LOCK_FILE="/tmp/daisy_industrial_ingest_chem.lock"
SQLITE_DB="${PROJECT_ROOT}/database/daisy.db"

INGEST_CHEM="${TOOLS_DIR}/ingest_chem.sh"
GEN_CHUNKS="${TOOLS_DIR}/generate_chem_chunks.sh"

PG_HOST="127.0.0.1"
PG_USER="daisy"
PG_DB="daisy_pg"
PG_SCHEMA="daisy"

usage() {
  cat <<'EOF'
Usage:
  industrial_ingest_chem.sh "<pdf_filename_or_fullpath>"

Examples:
  industrial_ingest_chem.sh "10 - IDEXX_SangueCompleto_T4_T4Livre_17_03_2025.pdf"
  industrial_ingest_chem.sh "/home/paulo/projeto_daisy/import/pdfs/chemistry/10 - IDEXX_....pdf"

Notes:
  - This script will:
    * generate raw_layout under ~/projeto_daisy/import/raw/
    * run ingest_chem.sh (dry-run then run)
    * insert a row into Postgres daisy.documents (source_type='pdf')
    * run generate_chem_chunks.sh <collection_date>
EOF
}

die() { echo "ERROR: $*" >&2; exit 1; }

need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }

timestamp() { date +"%Y-%m-%d_%H%M%S"; }

ensure_dirs() {
  mkdir -p "${RAW_DIR}" "${LOG_DIR}"
}

acquire_lock() {
  exec 9>"${LOCK_FILE}"
  if ! flock -n 9; then
    die "another ingestion is running (lock: ${LOCK_FILE})"
  fi
}

# Extract collection_date (YYYY-MM-DD) from the raw_layout.
# Strategy: take the FIRST occurrence of a dd.mm.yyyy date (IDEXX receipt style),
# convert to yyyy-mm-dd, and treat it as collection_date.
extract_collection_date() {
  local raw="$1"
  local d
  d="$(grep -aoE '[0-9]{2}\.[0-9]{2}\.[0-9]{4}' "$raw" | head -n 1 || true)"
  [[ -n "$d" ]] || return 1
  # dd.mm.yyyy -> yyyy-mm-dd
  echo "$d" | awk -F. '{printf "%04d-%02d-%02d\n",$3,$2,$1}'
}

# If this PDF was already ingested, SQLite is authoritative for collection_date.
sqlite_collection_date_by_source() {
  local pdf_name="$1"
  local pdf_sql
  pdf_sql="${pdf_name//\'/\'\'}"  # escape single quotes for SQLite

  sqlite3 -noheader -batch "${SQLITE_DB}" \
    "SELECT collection_date FROM chemistry WHERE source='${pdf_sql}' LIMIT 1;" \
    2>/dev/null || true
}

# Insert (or keep) a PDF document row for this collection_date.
# Deterministic: if a PDF row already exists for that date, do NOTHING.
insert_pg_document_if_missing() {
  local collection_date="$1"
  local pdf_name="$2"

  psql -h "${PG_HOST}" -U "${PG_USER}" -d "${PG_DB}" -v ON_ERROR_STOP=1 -c "
    INSERT INTO ${PG_SCHEMA}.documents (collection_date, source_type, source_path)
    SELECT DATE '${collection_date}', 'pdf', '${pdf_name}'
    WHERE NOT EXISTS (
      SELECT 1 FROM ${PG_SCHEMA}.documents
      WHERE collection_date = DATE '${collection_date}'
        AND source_type = 'pdf'
    );
  " >/dev/null
}

main() {
  [[ $# -eq 1 ]] || { usage; exit 1; }

  need_cmd pdftotext
  need_cmd psql
  need_cmd flock
  need_cmd grep
  need_cmd awk
  need_cmd sqlite3

  [[ -x "${INGEST_CHEM}" ]] || die "ingest_chem.sh not executable: ${INGEST_CHEM}"
  [[ -x "${GEN_CHUNKS}" ]] || die "generate_chem_chunks.sh not executable: ${GEN_CHUNKS}"

  ensure_dirs
  acquire_lock

  local arg="$1"
  local pdf_path pdf_name

  if [[ "$arg" == /* ]]; then
    pdf_path="$arg"
  else
    pdf_path="${PDF_DIR}/$arg"
  fi

  [[ -f "${pdf_path}" ]] || die "pdf not found: ${pdf_path}"
  pdf_name="$(basename "${pdf_path}")"

  local run_ts log_file
  run_ts="$(timestamp)"
  log_file="${LOG_DIR}/industrial_ingest_chem_${run_ts}.log"

  {
    echo "------------------------------------------------------------"
    echo "industrial_ingest_chem.sh"
    echo "timestamp: ${run_ts}"
    echo "pdf_path:  ${pdf_path}"
    echo "pdf_name:  ${pdf_name}"
    echo "------------------------------------------------------------"
  } | tee -a "${log_file}"

  # 1) raw_layout
  local raw_path
  raw_path="${RAW_DIR}/${run_ts}__${pdf_name// /_}__raw
